# Database - Production / Development / Testing
# The main PostgreSQL database URL for the legal corpus backend.
# Used by: run-real-ingestion.ts, inspect-documents.ts, validate-idempotency.ts
# Required: Yes (defaults to localhost if not set)
DATABASE_URL=postgresql://postgres:password@localhost:5432/phaplyviet_legal

# Database - Testing
# Separate PostgreSQL database URL for integration tests.
# Used by: tests/postgres-integration.test.ts
# Required: No (defaults to localhost_test if not set)
# Note: Only needed if RUN_DB_TESTS is set to true
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/phaplyviet_legal_test

# Testing
# Flag to enable PostgreSQL integration tests. Tests are skipped by default to avoid CI failures.
# Used by: tests/postgres-integration.test.ts
# Required: No (defaults to undefined/false if not set)
# Valid values: any non-empty string to enable (e.g., "1", "true", "yes")
RUN_DB_TESTS=1
